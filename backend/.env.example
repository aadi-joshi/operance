# OpenAI
OPENAI_API_KEY=sk-...

# Base Network
BASE_RPC_URL=https://sepolia.base.org
BASE_CHAIN_ID=84532
NETWORK=base-sepolia

# For mainnet: BASE_RPC_URL=https://mainnet.base.org, BASE_CHAIN_ID=8453, NETWORK=base

# Agent Master Mnemonic (BIP39, derives all wallets)
# Generate at: https://iancoleman.io/bip39/
AGENT_MASTER_MNEMONIC=word1 word2 word3 word4 word5 word6 word7 word8 word9 word10 word11 word12

# Registry Contract (from contracts/deploy)
REGISTRY_CONTRACT_ADDRESS=0x...

# Server
PORT=3001
FRONTEND_URL=http://localhost:3000

# Demo mode: set to "true" to skip real blockchain transactions
DEMO_MODE=false
